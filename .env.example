TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=34422887
# SSRF guard: set to true only if this instance should reach internal/private hosts
POTOK_ALLOW_PRIVATE_URLS=false
# Base URL used in approval links sent to Telegram
POTOK_PUBLIC_URL=http://localhost:8080
# Native Telegram button taps + recipient ingest (getUpdates long-poll);
# false = approvals use URL buttons and no auto recipient registration
POTOK_TELEGRAM_POLL_UPDATES=true

# Encryption key for dashboard-stored secrets (SMTP password). base64 32 bytes:
#   openssl rand -base64 32
# Required ONLY to store SMTP credentials via the dashboard; env SMTP_* below
# works without it.
POTOK_SECRET_KEY=

# Email delivery channel (SMTP) — all optional; unset = the email action fails
# gracefully. Works with any SMTP provider. Gmail: host smtp.gmail.com, port
# 587, username = your address, password = a 16-char app password (needs 2FA).
# Can also be configured from the dashboard (Settings → Email); DB config wins.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Sender address; defaults to SMTP_USERNAME. Gmail requires it to match the account.
SMTP_FROM=
SMTP_STARTTLS=true
SMTP_AUTH=true
