<?xml version="1.0" encoding="UTF-8"?>
<!-- Plain-text logging (default). Selected via logging.config in application.yml;
     POTOK_LOG_JSON=true switches to logback-json-true.xml. -->
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} wf=%X{workflow_name:-} exec=%X{execution_id:-} - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
